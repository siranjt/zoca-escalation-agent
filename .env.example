# Anthropic — used by lib/agent.ts to triage / draft / summarize
ANTHROPIC_API_KEY=

# Chargebee (Zoca production site)
CHARGEBEE_SITE=zoca
CHARGEBEE_API_KEY=

# Metabase (Zoca) — public CSV endpoints don't need a token,
# but the BaseSheet card 1335 requires session auth. Provide a
# session token for that path; the public CSVs work without it.
METABASE_BASE_URL=https://metabase.zoca.ai
METABASE_SESSION_TOKEN=

# Optional: shared secret for incoming webhooks (POST /api/webhook).
# When set, the route requires `x-zoca-webhook-secret: <value>`.
WEBHOOK_SHARED_SECRET=

# Linear API key — NO LONGER REQUIRED. Tickets are now sourced from a Metabase
# public CSV (entity-joined). You can leave LINEAR_API_KEY unset and remove it
# from Vercel.
# LINEAR_API_KEY=
